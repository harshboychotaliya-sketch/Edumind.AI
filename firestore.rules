rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function verified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // 2. Entity Validations
    function isValidUserProfile(data) {
      return data.keys().hasAll(['userId', 'email', 'displayName', 'weakPoints', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 128 &&
             data.weakPoints is list &&
             data.createdAt is string;
    }

    function isValidTestResult(data) {
      return data.keys().hasAll(['score', 'totalQuestions', 'weakAreas', 'timestamp']) &&
             data.score is number &&
             data.totalQuestions is number &&
             data.weakAreas is list &&
             data.timestamp is string;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      
      allow create: if isOwner(userId) && verified() && isValidUserProfile(request.resource.data);
      
      allow update: if isOwner(userId) && verified() && (
        // Action: Update Profile or Weak Points
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'weakPoints', 'updatedAt']))
      );

      match /materials/{materialId} {
        allow read, write: if isOwner(userId) && verified() && isValidId(materialId);
      }

      match /testResults/{resultId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && verified() && isValidTestResult(request.resource.data);
      }
    }
  }
}
