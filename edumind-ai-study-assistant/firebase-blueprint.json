{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the student and their study progress",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "weakPoints": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    },
    "StudyMaterial": {
      "title": "Study Material",
      "description": "Uploaded documents and their summaries",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fileName": { "type": "string" },
        "content": { "type": "string" },
        "summary": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "fileName", "content"]
    },
    "TestResult": {
      "title": "Test Result",
      "description": "Scores and feedback from practice tests",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "topic": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "weakAreas": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "topic", "score"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data"
    },
    "/users/{userId}/materials/{materialId}": {
      "schema": "StudyMaterial",
      "description": "Study materials uploaded by user"
    },
    "/users/{userId}/testResults/{resultId}": {
      "schema": "TestResult",
      "description": "History of practice tests"
    }
  }
}
